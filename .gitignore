# dependencies
node_modules/

# build
dist/
.next/
.turbo/

# env — never commit ANY env file (incl. timestamped backups)
.env
.env.*
!.env.example

# db
packages/db/prisma/migrations/

# ide
.vscode/
.idea/

# os
.DS_Store
Thumbs.db

# logs
*.log
deploy.sh

.claude/

# backups & db dumps
backups/
*.sql
*.sql.gz
*.sql.gz.gpg

# stray / editor files
*.save
endscreen.html

# dapp-store: never commit signing material, keypairs, or built APKs
*.keystore
*.jks
apps/mobile/dapp-store/build/
apps/mobile/dapp-store/assets/*.png
apps/mobile/dapp-store/assets/screenshots/*.png
*-publisher.json
*-publisher-keypair.json
