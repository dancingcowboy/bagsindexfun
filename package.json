{
  "name": "bags-index",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter @bags-index/db generate",
    "db:push": "pnpm --filter @bags-index/db push",
    "db:migrate": "pnpm --filter @bags-index/db migrate",
    "db:studio": "pnpm --filter @bags-index/db studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
