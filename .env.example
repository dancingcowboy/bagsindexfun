# Database
DATABASE_URL=postgresql://bags:bags_dev_password@localhost:5432/bags_index

# Redis
REDIS_URL=redis://localhost:6379

# Privy
PRIVY_APP_ID=                      # from Privy dashboard
PRIVY_APP_SECRET=                  # server-side only
NEXT_PUBLIC_PRIVY_APP_ID=          # client-side (same value as PRIVY_APP_ID)

# Solana
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=                    # for DAS API calls
SOLANA_NETWORK=mainnet-beta        # mainnet-beta | devnet

# Bags API
BAGS_API_KEY=                      # from Bags developer portal

# Jupiter — optional API key from portal.jup.ag. Without a key the free
# keyless tier allows only 0.5 RPS / 30 RPM; with a free key: 1 RPS / 60 RPM.
JUPITER_API_KEY=

# Platform Token — $BAGSX mint. Every index vault holds a fixed 8% exposure
# to this token (user vaults and the system vault alike). Sold back to SOL
# on withdrawal.
PLATFORM_TOKEN_MINT=DTp6oMA51WydSAcqY8cgYCFTtQXcQHNq5geCSgrwBAGS

# Vault wallet — protocol-owned index vault, receives fee-share claims from
# Bags. Auto-claimed every 4h and reallocated into the same 8%-BAGSX index
# composition as user vaults. Created as a Privy Server Wallet via
# scripts/create-vault-wallet.ts
VAULT_WALLET_ADDRESS=              # public key of the Privy Server Wallet
VAULT_PRIVY_WALLET_ID=             # Privy walletId for signing claim txs

# API Server
PORT=3001                          # local dev; production uses 3301
JWT_SECRET=                        # min 32 chars, generate with: openssl rand -hex 32
WEB_URL=http://localhost:3000      # production: https://bagsindex.fun
NEXT_PUBLIC_API_URL=http://localhost:3001  # production: https://bagsindex.fun/api
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com  # web client: used to build+confirm deposit transfers
NODE_ENV=development
LOG_LEVEL=info

# Claude Max Proxy (runs on same server in production)
CLAUDE_API_BASE_URL=http://127.0.0.1:3456        # localhost in prod
CLAUDE_API_KEY=no-key-needed                      # proxy handles auth
CLAUDE_MODEL=claude-sonnet-4-20250514             # model for daily analysis

# Admin
ADMIN_WALLETS=                     # comma-separated Solana wallet addresses
LAUNCH_ALLOWED_WALLETS=            # pre-launch allowlist (comma-separated). Empty = open to all. Admins are always allowed.

# X (Twitter) launch campaign — same OAuth1.0a app as tax-ai, regenerated
# access token under @bagsIndexSol via the Twitter dev portal
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Unsplash — used by /admin/tweets/prefill-images and /admin/tweets/unsplash
UNSPLASH_ACCESS_KEY=

# Telegram — mirrors every X post into a chat (campaign tweets)
TELEGRAM_BOT_TOKEN=                # from @BotFather
TELEGRAM_CHAT_ID=                  # numeric chat ID (use @userinfobot to find)
